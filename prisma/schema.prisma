generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String?        @unique
  phone         String?        @unique
  name          String?
  avatarUrl     String?
  ratingAvg     Float          @default(0)
  ratingCount   Int            @default(0)
  isAdmin       Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  listings      Listing[]
  offersMade    Offer[]        @relation("BuyerOffers")
  offerEvents   OfferEvent[]   @relation("OfferEventActor")
  notifications Notification[]
}

model Listing {
  id          String   @id @default(cuid())
  sellerId    String
  brand       String
  slug        String
  category    String
  faceValue   Decimal  @db.Decimal(10, 2)
  askingPrice Decimal  @db.Decimal(10, 2)
  expiryDate  DateTime
  couponType  String
  imageUrl    String?
  status      String   @default("active")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  seller      User     @relation(fields: [sellerId], references: [id])
  offers      Offer[]

  @@index([sellerId])
  @@index([status])
  @@index([category])
  @@index([brand])
  @@index([expiryDate])
}

model Offer {
  id        String       @id @default(cuid())
  listingId String
  listing   Listing      @relation(fields: [listingId], references: [id])
  buyerId   String
  buyer     User         @relation("BuyerOffers", fields: [buyerId], references: [id])
  amount    Decimal      @db.Decimal(10, 2)
  status    String       @default("pending")
  expiresAt DateTime
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  events    OfferEvent[]

  @@unique([listingId, buyerId])
  @@index([listingId])
  @@index([buyerId])
  @@index([status])
  @@index([expiresAt])
}

model OfferEvent {
  id        String   @id @default(cuid())
  offerId   String
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  type      String
  amount    Decimal? @db.Decimal(10, 2)
  actorId   String
  actor     User     @relation("OfferEventActor", fields: [actorId], references: [id])
  message   String?
  createdAt DateTime @default(now())

  @@index([offerId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}
